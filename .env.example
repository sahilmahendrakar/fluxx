# Firebase Web SDK config (renderer). All values are public; it's safe to ship
# them in the built app. Find them in the Firebase console → Project settings →
# Your apps → Web app → SDK setup and configuration.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google OAuth 2.0 "Desktop app" client used by the main process for the
# loopback PKCE sign-in flow. The client_secret is not a real secret per
# RFC 8252, but Google's token endpoint still requires it. Create the client
# at https://console.cloud.google.com/apis/credentials (Create credentials →
# OAuth client ID → Desktop app), then in Firebase Auth → Google provider,
# add the same client ID to the allowed client IDs list.
VITE_GOOGLE_DESKTOP_CLIENT_ID=
VITE_GOOGLE_DESKTOP_CLIENT_SECRET=
