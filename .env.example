# Firebase Web SDK config (renderer). All values are public; it's safe to ship
# them in the built app. Find them in the Firebase console → Project settings →
# Your apps → Web app → SDK setup and configuration.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google OAuth 2.0 "Desktop app" client used by the main process for the
# loopback PKCE sign-in flow. The client_secret is not a real secret per
# RFC 8252, but Google's token endpoint still requires it. Create the client
# at https://console.cloud.google.com/apis/credentials (Create credentials →
# OAuth client ID → Desktop app), then in Firebase Auth → Google provider,
# add the same client ID to the allowed client IDs list.
VITE_GOOGLE_DESKTOP_CLIENT_ID=
VITE_GOOGLE_DESKTOP_CLIENT_SECRET=

# Resend (transactional email) for team invites. Ships in the main-process
# bundle, so anyone with the app binary can extract the key. Acceptable for
# dev; for production, move email-sending to a Firebase Cloud Function triggered
# by writes to `projects/{pid}/invites/{email}` and keep the key server-side.
RESEND_API_KEY=
# Verified sending domain in Resend (e.g. example.com).
RESEND_FROM_DOMAIN=
# Display name for the From header (e.g. "Fluxx Ops").
RESEND_FROM_NAME=
# URL embedded in invite emails as the "Open Fluxx" button. Defaults to the
# local Vite dev server (http://localhost:5173) if unset.
FLUXX_APP_URL=
# Legacy name (still read by EmailService when FLUXX_APP_URL is unset).
# FLUX_APP_URL=
