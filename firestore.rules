rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(pid) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/projects/$(pid)).data.memberIds;
    }

    function isOwner(pid) {
      return isSignedIn()
        && request.auth.uid == get(/databases/$(database)/documents/projects/$(pid)).data.ownerId;
    }

    /**
     * Cloud tasks may persist `repoId` (multi-repo2). When the project doc lists
     * `repos` (shared repo metadata), constrain writes to known ids. Legacy
     * projects without `repos` cannot be checked here — allow reasonable strings.
     */
    function taskRepoIdKeyAbsentOrValid(pid, data) {
      return !data.keys().hasAny(['repoId'])
        || data.repoId == null
        || taskRepoIdFieldValid(pid, data.repoId);
    }

    function taskRepoIdFieldValid(pid, rid) {
      return rid is string
        && rid.size() > 0
        && rid.size() <= 200
        && taskRepoIdAllowedForProject(pid, rid);
    }

    function taskRepoIdAllowedForProject(pid, rid) {
      let pdata = get(/databases/$(database)/documents/projects/$(pid)).data;
      return !pdata.keys().hasAny(['repos'])
        || pdata.repos == null
        || !(pdata.repos is list)
        || pdata.repos.size() == 0
        || repoIdInSharedReposArray(pdata.repos, rid);
    }

    function repoAtMatches(repos, idx, rid) {
      return repos.size() > idx
        && repos[idx] is map
        && repos[idx].keys().hasAny(['id'])
        && repos[idx].id == rid;
    }

    /** Bounded scan (Firestore rules have no loops); supports up to 32 shared repos. */
    function repoIdInSharedReposArray(repos, rid) {
      return repoAtMatches(repos, 0, rid)
        || repoAtMatches(repos, 1, rid)
        || repoAtMatches(repos, 2, rid)
        || repoAtMatches(repos, 3, rid)
        || repoAtMatches(repos, 4, rid)
        || repoAtMatches(repos, 5, rid)
        || repoAtMatches(repos, 6, rid)
        || repoAtMatches(repos, 7, rid)
        || repoAtMatches(repos, 8, rid)
        || repoAtMatches(repos, 9, rid)
        || repoAtMatches(repos, 10, rid)
        || repoAtMatches(repos, 11, rid)
        || repoAtMatches(repos, 12, rid)
        || repoAtMatches(repos, 13, rid)
        || repoAtMatches(repos, 14, rid)
        || repoAtMatches(repos, 15, rid)
        || repoAtMatches(repos, 16, rid)
        || repoAtMatches(repos, 17, rid)
        || repoAtMatches(repos, 18, rid)
        || repoAtMatches(repos, 19, rid)
        || repoAtMatches(repos, 20, rid)
        || repoAtMatches(repos, 21, rid)
        || repoAtMatches(repos, 22, rid)
        || repoAtMatches(repos, 23, rid)
        || repoAtMatches(repos, 24, rid)
        || repoAtMatches(repos, 25, rid)
        || repoAtMatches(repos, 26, rid)
        || repoAtMatches(repos, 27, rid)
        || repoAtMatches(repos, 28, rid)
        || repoAtMatches(repos, 29, rid)
        || repoAtMatches(repos, 30, rid)
        || repoAtMatches(repos, 31, rid);
    }

    match /projects/{pid} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.memberIds;

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.memberIds.size() == 1
        && request.resource.data.memberIds[0] == request.auth.uid
        && request.resource.data.schemaVersion == 1
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;

      // Owner can do anything. Members can update non-ownership fields (name,
      // etc.) but cannot change ownerId or memberIds — those are owner-only.
      // Invitees can add themselves to memberIds iff a matching invite exists.
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.ownerId
        || (
          request.auth.uid in resource.data.memberIds
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.memberIds == resource.data.memberIds
        )
        || (
          // Invite-accept: non-member adds only their own uid, nothing else changes.
          !(request.auth.uid in resource.data.memberIds)
          && request.auth.token.email_verified == true
          && exists(/databases/$(database)/documents/projects/$(pid)/invites/$(request.auth.token.email.lower()))
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.memberIds.hasAll(resource.data.memberIds)
          && request.resource.data.memberIds.hasOnly(resource.data.memberIds.concat([request.auth.uid]))
          && request.auth.uid in request.resource.data.memberIds
        )
      );

      allow delete: if isSignedIn() && request.auth.uid == resource.data.ownerId;

      match /members/{uid} {
        allow read: if isMember(pid);
        allow write: if isOwner(pid) || (isSignedIn() && request.auth.uid == uid);
      }

      match /tasks/{tid} {
        allow read: if isMember(pid);
        allow create: if isMember(pid)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.updatedBy == request.auth.uid
          && taskRepoIdKeyAbsentOrValid(pid, request.resource.data);
        allow update: if isMember(pid)
          && request.resource.data.updatedBy == request.auth.uid
          && taskRepoIdKeyAbsentOrValid(pid, request.resource.data);
        allow delete: if isMember(pid);

        match /runners/{uid} {
          allow read: if isMember(pid);
          // A user can only write their own runner doc.
          allow write: if isSignedIn() && request.auth.uid == uid;
        }
      }

      // Planning markdown mirrors (`relativePath` ends with `.md`); not machine-local Flux config.
      match /planningDocs/{docId} {
        allow read: if isMember(pid);

        allow create: if isMember(pid)
          && request.resource.data.schemaVersion == 1
          && request.resource.data.relativePath is string
          && request.resource.data.relativePath.size() > 0
          && request.resource.data.relativePath.size() < 2048
          && request.resource.data.markdown is string
          && request.resource.data.markdown.size() < 950000
          && request.resource.data.updatedBy == request.auth.uid
          && request.resource.data.updatedAt is timestamp;

        allow update: if isMember(pid)
          && resource.data.schemaVersion == 1
          && request.resource.data.schemaVersion == 1
          && request.resource.data.relativePath == resource.data.relativePath
          && request.resource.data.markdown is string
          && request.resource.data.markdown.size() < 950000
          && request.resource.data.updatedBy == request.auth.uid
          && request.resource.data.updatedAt is timestamp;

        allow delete: if isMember(pid);

        match /conflicts/{conflictId} {
          allow read: if isMember(pid);

          allow create: if isMember(pid)
            && request.resource.data.schemaVersion == 1
            && request.resource.data.relativePath is string
            && request.resource.data.relativePath.size() > 0
            && request.resource.data.relativePath.size() < 2048
            && request.resource.data.localMarkdown is string
            && request.resource.data.localMarkdown.size() < 950000
            && request.resource.data.remoteMarkdown is string
            && request.resource.data.remoteMarkdown.size() < 950000
            && request.resource.data.remoteRevision is string
            && request.resource.data.remoteUpdatedBy is string
            && request.resource.data.localUpdatedBy == request.auth.uid
            && request.resource.data.createdAt is timestamp
            && (
              request.resource.data.baseRemoteRevision == null
              || request.resource.data.baseRemoteRevision is string
            );
        }
      }

      match /invites/{email} {
        // An invited user can see their own invites; members can see any.
        allow read: if isMember(pid)
          || (isSignedIn()
            && request.auth.token.email_verified == true
            && request.auth.token.email.lower() == email);

        // Only the owner can invite. The doc id and the `email` field must
        // agree and be lowercased.
        allow create: if isOwner(pid)
          && request.resource.data.email == email
          && email == email.lower();

        // Owner can update invite metadata (e.g. backfilling projectName onto
        // legacy invites that pre-date denormalization). The email field is
        // immutable so the doc id and email stay in sync.
        allow update: if isOwner(pid)
          && request.resource.data.email == resource.data.email;

        // Owner can cancel. Invited user can delete their own invite
        // (accept/decline flow ends with deleting it).
        allow delete: if isOwner(pid)
          || (isSignedIn()
            && request.auth.token.email_verified == true
            && request.auth.token.email.lower() == email);
      }
    }

    // Collection-group read: lets a signed-in user discover their pending
    // invites across all projects via collectionGroup('invites'). The query
    // must filter by the email field; this rule aligns the auth email with
    // resource.data.email so Firestore's static analysis admits it.
    match /{path=**}/invites/{email} {
      allow read: if isSignedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() == resource.data.email;
    }

    // Collection-group read: lets project members watch realtime runner
    // presence across all tasks via collectionGroup('runners'). The runner
    // doc carries projectId; membership is checked against that project.
    match /{path=**}/runners/{uid} {
      allow read: if isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.memberIds;
    }
  }
}
