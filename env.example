# Copy to `.env` for local dev. For CI releases, add the same names as GitHub Actions
# repository secrets (see docs/macos-github-releases.md).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

VITE_GOOGLE_DESKTOP_CLIENT_ID=
VITE_GOOGLE_DESKTOP_CLIENT_SECRET=

RESEND_API_KEY=
RESEND_FROM_DOMAIN=
RESEND_FROM_NAME=

# Optional: Apple signing for local `pnpm make` (CI uses GitHub secrets instead).
# APPLE_ID=
# APPLE_PASSWORD=
# APPLE_TEAM_ID=
