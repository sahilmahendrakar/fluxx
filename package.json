{
  "name": "flux",
  "productName": "Flux",
  "version": "0.1.1",
  "description": "Task-driven AI agent orchestration for developers",
  "main": ".vite/build/main.js",
  "packageManager": "pnpm@10.29.3",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "start:aux": "electron-forge start -- --user-data-dir=.flux-test-userdata",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "postinstall": "electron-rebuild -f -w node-pty && node scripts/rebuild-dmg-native-deps.cjs"
  },
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/sahilmahendrakar/flux-web.git"
  },
  "author": {
    "name": "Sahil Mahendrakar",
    "email": "sahil.mahendrakar@gmail.com"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "fs-xattr",
      "macos-alias",
      "node-pty"
    ]
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron/fuses": "^1.0.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "electron": "41.2.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.0.1",
    "eslint-plugin-import": "^2.25.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3",
    "typescript": "~5.4.5",
    "vite": "^5.0.12",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@lucide/lab": "^0.1.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.3",
    "firebase": "^12.12.0",
    "fractional-indexing": "^3.2.0",
    "lucide-react": "^1.8.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  }
